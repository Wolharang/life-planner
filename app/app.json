{
  "expo": {
    "name": "LifePlanner",
    "slug": "lifeplanner",
    "scheme": "lifeplanner",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "android": {
      "package": "com.lifeplanner.app",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "SCHEDULE_EXACT_ALARM",
        "USE_EXACT_ALARM",
        "USE_FULL_SCREEN_INTENT",
        "RECEIVE_BOOT_COMPLETED",
        "POST_NOTIFICATIONS",
        "VIBRATE",
        "WAKE_LOCK",
        "REQUEST_IGNORE_BATTERY_OPTIMIZATIONS"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "./plugins/withExecutionLockScreen",
      "expo-font",
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      "expo-build-properties"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "bundleIdentifier": "com.lifeplanner.app"
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "c2e60ce5-73dd-45d2-a78a-65ce1c99d5b3"
      }
    }
  }
}

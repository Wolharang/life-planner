{
  "expo": {
    "name": "LifePlanner",
    "slug": "lifeplanner",
    "scheme": "lifeplanner",
    "version": "0.5.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "android": {
      "package": "com.lifeplanner.app",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "SCHEDULE_EXACT_ALARM",
        "USE_EXACT_ALARM",
        "USE_FULL_SCREEN_INTENT",
        "RECEIVE_BOOT_COMPLETED",
        "POST_NOTIFICATIONS",
        "VIBRATE",
        "WAKE_LOCK",
        "REQUEST_IGNORE_BATTERY_OPTIMIZATIONS",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAFAFA"
      },
      "versionCode": 7
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "./plugins/withExecutionLockScreen",
      "./plugins/withReleaseHeap",
      "expo-font",
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      "expo-build-properties",
      "@react-native-google-signin/google-signin",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "헬스·러닝 실행이 실제로 이뤄졌는지 자동으로 판정하기 위해 위치를 사용해요.",
          "locationWhenInUsePermission": "헬스·러닝 실행이 실제로 이뤄졌는지 자동으로 판정하기 위해 위치를 사용해요.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "bundleIdentifier": "com.lifeplanner.app"
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "c2e60ce5-73dd-45d2-a78a-65ce1c99d5b3"
      }
    },
    "icon": "./assets/icon.png"
  }
}
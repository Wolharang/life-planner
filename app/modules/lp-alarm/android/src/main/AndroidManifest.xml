<manifest xmlns:android="http://schemas.android.com/apk/res/android">

  <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
  <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
  <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
  <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
  <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
  <uses-permission android:name="android.permission.VIBRATE" />
  <uses-permission android:name="android.permission.WAKE_LOCK" />
  <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
  <!--
    "다른 앱 위에 표시". THE fix for "the moment only appeared as a heads-up notification":
    a full-screen intent launches its activity immediately ONLY while the screen is off/locked — on an
    UNLOCKED, in-use phone Android degrades it to a heads-up banner, and a BroadcastReceiver's direct
    startActivity is blocked by the background-activity-start restriction (Android 10+). Holding this
    permission lifts that restriction, so the execution moment appears at its time either way.
  -->
  <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

  <application>

    <!-- Fires at the exact time (setAlarmClock). Not exported: only our own PendingIntent triggers it. -->
    <receiver
      android:name="com.lifeplanner.lpalarm.AlarmReceiver"
      android:exported="false" />

    <!-- Grabs one GPS fix at +5m / +15m for a committed workout/run 실행 block (auto-evaluation). Not
         exported: only our own PendingIntent triggers it. -->
    <receiver
      android:name="com.lifeplanner.lpalarm.GeoReceiver"
      android:exported="false" />

    <!-- Re-registers alarms from the native mirror after reboot / time / timezone change. -->
    <receiver
      android:name="com.lifeplanner.lpalarm.BootReceiver"
      android:exported="true">
      <intent-filter>
        <action android:name="android.intent.action.BOOT_COMPLETED" />
        <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
        <action android:name="android.intent.action.TIME_SET" />
        <action android:name="android.intent.action.TIMEZONE_CHANGED" />
        <!-- Android 12+: the user just granted exact alarms. Without this, every block scheduled while the
             permission was denied stayed unarmed until the app happened to be opened — the lever silently
             dead, and nothing saying so. §11 layer 4 claimed this broadcast; nothing had registered it. -->
        <action android:name="android.app.action.SCHEDULE_EXACT_ALARM_PERMISSION_STATE_CHANGED" />
      </intent-filter>
    </receiver>

    <!--
      The execution moment, shown OVER the lock screen.

      configChanges + a locked orientation are NOT cosmetic here. Without them, ANY configuration change —
      a rotation, dark mode, a font-size or locale change — destroys and recreates the activity. onCreate
      then re-runs startItem() with the original commit intent, and because the moment is still unanswered
      it falls straight through to recording a SECOND fire marker and arming a SECOND re-check. Picking the
      phone up off a table was enough: the occurrence was counted twice in S1's latency data, and the
      catch-up net held two rows for it. The moment owns the screen for one minute; it has no business
      being rebuilt underneath the user.
    -->
    <activity
      android:name="com.lifeplanner.lpalarm.ExecutionActivity"
      android:exported="false"
      android:showWhenLocked="true"
      android:turnScreenOn="true"
      android:excludeFromRecents="true"
      android:launchMode="singleInstance"
      android:taskAffinity=".LpAlarmExecution"
      android:screenOrientation="portrait"
      android:configChanges="keyboard|keyboardHidden|orientation|screenSize|screenLayout|smallestScreenSize|uiMode|locale|layoutDirection|fontScale|density"
      android:theme="@android:style/Theme.Material.Light.NoActionBar" />

  </application>
</manifest>

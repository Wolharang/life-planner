rules_version = '2';

// LifePlanner security rules (P-b · data-model §6 · architecture §3).
//
// The whole model is one sentence: **a user can touch their own documents and nothing else.** This is a
// single-user personal app (D3), so there is no sharing, no public read, no admin path — anything not
// written here is denied by default, which is exactly what we want.
//
// Deletes are SOFT (§6): the client writes a `deletedAt` tombstone instead of removing the document, so the
// other device can hear about the deletion. Hard `delete` is therefore not allowed — a hard delete would
// vanish without a trace and the other phone would simply push the row back up.

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      // The owner, and only the owner. `request.auth == null` (logged out) fails this, so an
      // unauthenticated client can read nothing at all.
      function isOwner() {
        return request.auth != null && request.auth.uid == uid;
      }

      // **The account tombstone (D76), and why the server has to be the one enforcing it.**
      //
      // 회원 탈퇴 happens on ONE phone. The others are still logged in, still holding rows, and — this is the
      // part that bites — **still holding a valid ID token for up to an hour after the user is deleted.**
      // Firebase does not revoke it mid-flight; the rules will happily accept their writes.
      //
      // And they *will* write: the reconcile's own rule is "a row the cloud has never seen is pushed up".
      // After the wipe the cloud has seen nothing, so the second phone would **push the whole account back**,
      // under a uid whose user no longer exists — data nobody can read and nobody can delete, forever.
      //
      // No client fix can close this: the offending client is another device, possibly an older build, acting
      // in good faith. So the last act of 탈퇴 is to leave a marker the server itself checks on every write.
      function accountClosed() {
        return exists(/databases/$(database)/documents/users/$(uid))
               && get(/databases/$(database)/documents/users/$(uid)).data.get('closedAt', null) != null;
      }

      // The tombstone may be written once, by its owner, and **read by anyone who already knows the uid**.
      //
      // Why public `get`: a phone that was offline longer than an ID token lives (~1h) is **signed out by
      // Firebase itself** the moment it reconnects — the deleted user cannot refresh. It would then never learn
      // that the account was closed, never carry out the "기기 기록도 지우기" the user chose, and never explain
      // its own sudden logout. An owner-only read is unreadable exactly when it is needed.
      //
      // What it costs: someone who *already has* a uid can learn that it was closed, when, and whether the
      // records were wiped. The document holds **no name, no email, nothing that identifies a person** — and
      // `list` stays denied, so the collection cannot be enumerated to go fishing for uids.
      //
      // It can never be edited away or deleted: if a client could remove it, the resurrection it exists to
      // prevent would simply resume, because the rules would see an ordinary, living account again.
      allow get: if true;
      allow list: if false;
      allow create: if isOwner() && request.resource.data.get('closedAt', null) != null;
      allow update, delete: if false;

      // **Consent is evidence, not state.** (D73/D74) One document per LEGAL_VERSION, carrying the second it
      // was given, per tick, and the device it was given on. It may be created and read — never rewritten,
      // never deleted. A consent record the client can edit is not a record of anything: the whole point is
      // that we can still show, later, exactly what was agreed to and when.
      //
      // NOTE: rules are evaluated with OR, so this cannot simply be "more specific" than the wildcard below —
      // the wildcard's `update` is explicitly withheld from this collection, or it would grant what this
      // match denies.
      match /consents/{docId} {
        allow read: if isOwner();
        allow create: if isOwner() && !accountClosed() && request.resource.data.id == docId;
        allow update: if false;
        // Deletable **only** as part of 회원 탈퇴: the 처리방침 (제7조) promises 파기, and 파기 cannot mean
        // "kept forever, unreadable". A consent that outlives the account it was given to is not evidence of
        // anything — there is no longer anyone it was given by.
        allow delete: if isOwner();
      }

      // The four synced collections (data-model §2). The measurement/catch-up stores
      // (lp.outcomes/fires/missed/latencies, §2.7) never leave the device, so they have no rule here.
      match /{collection}/{docId} {
        allow read: if isOwner();

        // The document's own id must match its path — the client-generated id is the join key everywhere
        // else (§0), so a row whose `id` disagrees with its document name would break the local projection.
        // **Nothing may be written to a closed account** — not by this phone, not by the other one that is
        // still logged in and still believes the account exists. See `accountClosed()` above.
        allow create: if isOwner() && !accountClosed() && request.resource.data.id == docId;

        // **A tombstone is TERMINAL: once dead, a row can never come back to life.** (D54)
        //
        // This is the server's own guard against the three-device case. Phone C edits a row while offline;
        // that write sits in Firestore's queue. Another phone deletes the row. C reconnects days later and
        // the queued write flushes UNCONDITIONALLY — it never passes through any client-side reconcile. If it
        // could clear `deletedAt`, the deleted block would return **and re-arm its alarm**. The client is
        // already careful never to send `deletedAt` on a push; this makes it impossible even if it slips.
        //
        // There is no "undelete" in this app: a block you re-create gets a new id.
        allow update: if isOwner()
                      && !accountClosed()
                      && collection != 'consents'   // evidence is append-only — see the match above
                      && request.resource.data.id == docId
                      && !(resource.data.get('deletedAt', null) != null
                           && request.resource.data.get('deletedAt', null) == null);

        // **Hard delete: the owner, and only for 파기.**
        //
        // This used to be `if false`, to force every removal through a tombstone — the tombstone is how the
        // *other* phone learns a row is gone (D53/D54), and a row that merely vanished would be pushed back up
        // by the next device to reconnect.
        //
        // But 이용약관 제6조 and 처리방침 제7조 promise that 탈퇴 destroys the server's copy, and on the free
        // plan there is no Cloud Function to do it for us: the client is the only thing that can. **A promise
        // of 파기 that the code cannot keep is worse than no promise at all**, so the owner may delete.
        //
        // The invariant survives in the client, which still soft-deletes every ordinary row (blockRepository)
        // and hard-deletes **only** when wiping an entire account (`erase.ts`) — where there is no other phone
        // left to inform, because the account itself is being destroyed.
        allow delete: if isOwner();
      }
    }
  }
}
